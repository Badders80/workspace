[default_model]
api_key_env = "OLLAMA_API_KEY"
model = "qwen3.5:latest"
provider = "ollama"

[[fallback_providers]]
api_key_env = "OPENROUTER_API_KEY"
model = "auto"
provider = "openrouter"

[[fallback_providers]]
api_key_env = "OPENAI_API_KEY"
model = "gpt-4o-mini"
provider = "openai"

[[fallback_providers]]
api_key_env = "GOOGLE_API_KEY"
model = "gemini-1.5-flash"
provider = "google"

[memory]
decay_rate = 0.05

[network]
listen_addr = "127.0.0.1:4200"
