#!/bin/bash
# ═══════════════════════════════════════════════════════════
# Evo Doctor - Sanity Check for Evolution Stables
# Run weekly or when things feel "off"
# ═══════════════════════════════════════════════════════════

EVO_ROOT="/home/evo"

# Colors (define FIRST)
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

ISSUES=0
WARNINGS=0

echo "🩺 Evo Doctor - Sanity Check"
echo "═══════════════════════════════════════════════════════════"
echo ""

# ═══════════════════════════════════════════════════════════
# CHECK 0: Universal AI Tool DNA Integration (Critical!)
# ═══════════════════════════════════════════════════════════

echo -e "${BLUE}🔧 Checking Universal AI Tool DNA Integration${NC}"

# Check kimic
if command -v kimic &>/dev/null; then
    KIMIC_PATH=$(command -v kimic)
    if [[ "$KIMIC_PATH" == */.local/bin/kimic ]]; then
        echo -e "  ${GREEN}✅${NC} kimic installed ($KIMIC_PATH)"
    else
        echo -e "  ${GREEN}✓${NC} kimic available ($KIMIC_PATH)"
    fi
else
    echo -e "  ${RED}❌${NC} kimic NOT FOUND"
    echo -e "  ${YELLOW}⚠${NC}  Install: cp _scripts/kimic.sh ~/.local/bin/kimic && chmod +x ~/.local/bin/kimic"
    ((WARNINGS++))
fi

# Check claudec
if command -v claudec &>/dev/null; then
    echo -e "  ${GREEN}✅${NC} claudec installed"
else
    echo -e "  ${YELLOW}⚠${NC}  claudec not installed (optional - for Claude CLI)"
fi

# Check aidere
if command -v aidere &>/dev/null; then
    echo -e "  ${GREEN}✅${NC} aidere installed"
else
    echo -e "  ${YELLOW}⚠${NC}  aidere not installed (optional - for Aider)"
fi

# Check geminic
if command -v geminic &>/dev/null; then
    echo -e "  ${GREEN}✅${NC} geminic installed"
else
    echo -e "  ${YELLOW}⚠${NC}  geminic not installed (optional - for Gemini CLI)"
fi

# Check kiloc
if command -v kiloc &>/dev/null; then
    echo -e "  ${GREEN}✅${NC} kiloc installed"
else
    echo -e "  ${YELLOW}⚠${NC}  kiloc not installed (optional - for Kilo CLI)"
fi

# Check dna-context
if command -v dna-context &>/dev/null; then
    echo -e "  ${GREEN}✅${NC} dna-context installed"
else
    echo -e "  ${RED}❌${NC} dna-context NOT FOUND"
    echo -e "  ${YELLOW}⚠${NC}  Install: cp _scripts/dna-context.sh ~/.local/bin/dna-context && chmod +x ~/.local/bin/dna-context"
    ((WARNINGS++))
fi

# Check VS Code Copilot instructions
if [[ -f "$EVO_ROOT/.github/copilot-instructions.md" ]]; then
    echo -e "  ${GREEN}✅${NC} GitHub Copilot instructions configured"
else
    echo -e "  ${YELLOW}⚠${NC}  .github/copilot-instructions.md not found (optional - for VS Code)"
fi

# Initialize counters if not already set
ISSUES=${ISSUES:-0}
WARNINGS=${WARNINGS:-0}

# ═══════════════════════════════════════════════════════════
# CHECK 1: DNA Exists (Source of Truth)
# ═══════════════════════════════════════════════════════════

echo -e "${BLUE}📚 Checking DNA (Source of Truth)${NC}"

if [[ -d "$EVO_ROOT/00_DNA" ]]; then
    echo -e "${GREEN}✅${NC} DNA directory exists"
    
    # Check key files
    KEY_FILES=("🏠 Home.md" "🏗️ Build Rules.md" "AGENTS.core.md" "🔐 Secrets Guide.md" "🧠 AI_CONTEXT.md")
    for file in "${KEY_FILES[@]}"; do
        if [[ -f "$EVO_ROOT/00_DNA/$file" ]]; then
            echo -e "  ${GREEN}✓${NC} $file"
        else
            echo -e "  ${YELLOW}⚠${NC} $file missing"
            ((WARNINGS++))
        fi
    done
else
    echo -e "${RED}❌${NC} DNA directory MISSING - This is critical!"
    ((ISSUES++))
fi

echo ""

# ═══════════════════════════════════════════════════════════
# CHECK 2: Vault Health (One Point for Keys)
# ═══════════════════════════════════════════════════════════

echo -e "${BLUE}🔐 Checking Vault (One Point for Keys)${NC}"

if [[ -f "$EVO_ROOT/.env" ]]; then
    perms=$(stat -c "%a" "$EVO_ROOT/.env")
    if [[ "$perms" == "600" ]]; then
        echo -e "${GREEN}✅${NC} Vault exists with secure permissions"
    else
        echo -e "${YELLOW}⚠${NC} Vault permissions: $perms (should be 600)"
        ((WARNINGS++))
    fi
else
    echo -e "${RED}❌${NC} Master vault missing at /evo/.env"
    ((ISSUES++))
fi

# Check project symlinks
PROJECT_COUNT=0
LINKED_COUNT=0
for proj in "$EVO_ROOT"/projects/Evolution_*/; do
    if [[ -d "$proj" ]]; then
        ((PROJECT_COUNT++))
        if [[ -L "$proj/.env" ]]; then
            ((LINKED_COUNT++))
        fi
    fi
done

if [[ $LINKED_COUNT -eq $PROJECT_COUNT ]]; then
    echo -e "${GREEN}✅${NC} All $PROJECT_COUNT projects linked to vault"
else
    echo -e "${YELLOW}⚠${NC} $LINKED_COUNT/$PROJECT_COUNT projects linked to vault"
    ((WARNINGS++))
fi

echo ""

# ═══════════════════════════════════════════════════════════
# CHECK 3: Project Structure (Layer Separation)
# ═══════════════════════════════════════════════════════════

echo -e "${BLUE}📁 Checking Project Structure${NC}"

# Check for projects directly in root (should be in projects/)
ROOT_FOLDERS=$(find "$EVO_ROOT" -maxdepth 1 -type d -name "Evolution_*" 2>/dev/null | wc -l)
if [[ $ROOT_FOLDERS -eq 0 ]]; then
    echo -e "${GREEN}✅${NC} No stray Evolution_* folders in root"
else
    echo -e "${YELLOW}⚠${NC} Found $ROOT_FOLDERS Evolution_* folders in root (should be in projects/)"
    find "$EVO_ROOT" -maxdepth 1 -type d -name "Evolution_*" | sed 's/^/    /'
    ((WARNINGS++))
fi

# Check layer separation
if [[ -d "$EVO_ROOT/projects/Infrastructure" ]]; then
    echo -e "${GREEN}✅${NC} Infrastructure layer properly separated"
fi

if [[ -d "$EVO_ROOT/projects/External" ]]; then
    echo -e "${GREEN}✅${NC} External dependencies properly separated"
fi

echo ""

# ═══════════════════════════════════════════════════════════
# CHECK 4: Documentation Currency
# ═══════════════════════════════════════════════════════════

echo -e "${BLUE}📄 Checking Documentation${NC}"

if [[ -f "$EVO_ROOT/FINAL_STRUCTURE.md" ]]; then
    echo -e "${GREEN}✅${NC} FINAL_STRUCTURE.md exists"
else
    echo -e "${YELLOW}⚠${NC} FINAL_STRUCTURE.md missing"
    ((WARNINGS++))
fi

if [[ -f "$EVO_ROOT/PROJECTS_INDEX.md" ]]; then
    echo -e "${GREEN}✅${NC} PROJECTS_INDEX.md exists"
else
    echo -e "${YELLOW}⚠${NC} PROJECTS_INDEX.md missing"
    ((WARNINGS++))
fi

echo ""

# ═══════════════════════════════════════════════════════════
# CHECK 5: Git Hygiene
# ═══════════════════════════════════════════════════════════

echo -e "${BLUE}⚡ Checking Git Hygiene${NC}"

# Check for .env files that might be committed
if [[ -d "$EVO_ROOT/00_DNA/.git" ]]; then
    cd "$EVO_ROOT/00_DNA"
    TRACKED_ENV=$(git ls-files | grep -E "\.env$" | head -5)
    if [[ -n "$TRACKED_ENV" ]]; then
        echo -e "${RED}❌${NC} .env files tracked in DNA git:"
        echo "$TRACKED_ENV" | sed 's/^/    /'
        ((ISSUES++))
    else
        echo -e "${GREEN}✅${NC} No .env files tracked in DNA"
    fi
fi

# Check .gitignore exists in DNA
if [[ -f "$EVO_ROOT/00_DNA/.gitignore" ]]; then
    if grep -q "\.env" "$EVO_ROOT/00_DNA/.gitignore"; then
        echo -e "${GREEN}✅${NC} .env in DNA .gitignore"
    else
        echo -e "${YELLOW}⚠${NC} .env not in DNA .gitignore"
        ((WARNINGS++))
    fi
fi

echo ""

# ═══════════════════════════════════════════════════════════
# SUMMARY
# ═══════════════════════════════════════════════════════════

echo "═══════════════════════════════════════════════════════════"
echo "📊 Summary"
echo "═══════════════════════════════════════════════════════════"

if [[ $ISSUES -eq 0 && $WARNINGS -eq 0 ]]; then
    echo -e "${GREEN}✅ All checks passed! Evo is healthy.${NC}"
    echo ""
    echo "Remember:"
    echo "  • DNA is the source of truth"
    echo "  • One vault (/evo/.env) for all keys"
    echo "  • Infrastructure ≠ Intelligence ≠ Content"
    exit 0
elif [[ $ISSUES -eq 0 ]]; then
    echo -e "${YELLOW}⚠ $WARNINGS warning(s) found${NC}"
    echo "These are suggestions, not critical issues."
    echo "Review above and fix if needed."
    exit 0
else
    echo -e "${RED}❌ $ISSUES issue(s) and $WARNINGS warning(s) found${NC}"
    echo ""
    echo "Critical issues should be fixed:"
    echo "  1. Check vault health: ./vault.sh check"
    echo "  2. Review DNA structure"
    echo "  3. Check project symlinks"
    exit 1
fi
